# TCDynamics Backend Environment Variables
# ──────────────────────────────────────────────────────────
# OPTIONAL: This Express server (port 8080) is for local dev only.
# The primary API runs as Vercel serverless functions (see api/).
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill with your actual values.
# NEVER commit the .env file to version control!

# Server Configuration
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:3100

# Database (MongoDB)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/tcdynamics

# Email (Resend — primary path is via Vercel serverless api/emails.js)
RESEND_API_KEY=re_your_resend_api_key_here
CONTACT_EMAIL=your_contact_email@example.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# Security — generate secure keys with: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-secure-random-string
ADMIN_API_KEY=change-this-to-another-secure-random-string

# CORS Configuration (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:3100,https://tcdynamics.fr,https://www.tcdynamics.fr

# Payments (Polar)
POLAR_ACCESS_TOKEN=your_polar_access_token_here
POLAR_SERVER=production
POLAR_PRODUCT_STARTER=your_starter_product_id
POLAR_PRODUCT_PROFESSIONAL=your_professional_product_id
POLAR_PRODUCT_ENTERPRISE=your_enterprise_product_id

# Monitoring (optional)
# SENTRY_DSN=
