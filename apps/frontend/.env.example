# TCDynamics Frontend Environment Variables
# Copy this file to .env.local for local development
# Server-only vars (non-VITE_*) go in Vercel project settings

# ============================================
# AUTHENTICATION (Clerk)
# ============================================

# Client-side publishable key (exposed to browser)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
# Dev mode: ThemedClerkProvider reads this key instead
VITE_CLERK_PREVIEW_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# ── Server-only (Vercel env / API) ──────────────────────
# CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_clerk_webhook_secret

# ============================================
# DATABASE (MongoDB)
# ============================================

# Server-only
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/tcdynamics

# ============================================
# AI CHAT (OpenRouter)
# ============================================

# Server-only
# OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
# OPENROUTER_MODEL=openrouter/free
# ALLOW_VERCEL_CHAT=true

# ============================================
# PAYMENTS (Polar)
# ============================================

# Server-only
# POLAR_ACCESS_TOKEN=your_polar_access_token_here
# POLAR_SERVER=production
# POLAR_PRODUCT_STARTER=your_starter_product_id
# POLAR_PRODUCT_PROFESSIONAL=your_professional_product_id
# POLAR_PRODUCT_ENTERPRISE=your_enterprise_product_id

# ============================================
# EMAIL (Resend)
# ============================================

# Server-only
# RESEND_API_KEY=re_your_resend_api_key_here
# CONTACT_EMAIL=contact@example.com
# DEMO_EMAIL=demo@yourdomain.com

# ============================================
# RATE LIMITING (Upstash Redis)
# ============================================

# Server-only — distributed rate limiting for serverless
# UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ============================================
# APPLICATION SETTINGS
# ============================================

VITE_API_URL=/api
VITE_FRONTEND_URL=https://your-app.vercel.app
VITE_NODE_ENV=development # Use production only in deployed environments
VITE_APP_VERSION=1.0.0

# ============================================
# FEATURE FLAGS
# ============================================

VITE_FEATURE_ENABLE_CONTACT_FORM=true
VITE_FEATURE_ENABLE_DEMO_FORM=true
VITE_FEATURE_ENABLE_AI_CHAT=false
VITE_FEATURE_ENABLE_AI_VISION=false
VITE_FEATURE_ENABLE_ANALYTICS=false
VITE_FEATURE_ENABLE_DEBUG_LOGGING=false
VITE_FEATURE_ENABLE_CACHE=true

# ============================================
# PERFORMANCE & SECURITY (defaults are fine)
# ============================================

VITE_CACHE_MAX_SIZE=1000
VITE_CACHE_DEFAULT_TTL=300000
VITE_CACHE_CLEANUP_INTERVAL=300000
VITE_PERFORMANCE_ENABLE_SAMPLING=true
VITE_PERFORMANCE_SAMPLE_RATE=0.1
VITE_PERFORMANCE_MAX_METRICS=1000
VITE_SECURITY_CSP_STRICT=true # Set to false only when you need to temporarily relax CSP
VITE_SECURITY_RATE_LIMIT_REQUESTS=100
VITE_SECURITY_RATE_LIMIT_WINDOW=60000

# ============================================
# OPTIONAL — Analytics (add later)
# ============================================

# VITE_ANALYTICS_GA_TRACKING_ID=G-XXXXXXXXXX
# VITE_ANALYTICS_HOTJAR_ID=XXXXXXX
# VITE_FACEBOOK_PIXEL_ID=your_facebook_pixel_id_here
